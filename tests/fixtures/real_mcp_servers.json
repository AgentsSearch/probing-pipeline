          "type": "object",
          "properties": {
            "query": { "type": "string", "description": "SELECT SQL query to execute" }
          },
          "required": ["query"]
        },
        "output_schema": {
          "type": "array",
          "items": { "type": "object" }
        },
        "complexity_estimate": 0.3
      },
      {
        "tool_name": "write_query",
        "description": "Execute an INSERT, UPDATE, or DELETE query on the SQLite database",
        "capability_tags": ["database", "sql", "write", "data_modification"],
        "parameter_schema": {
          "type": "object",
          "properties": {
            "query": { "type": "string", "description": "SQL query to execute (INSERT, UPDATE, or DELETE)" }
          },
          "required": ["query"]
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "affected_rows": { "type": "integer" }
          }
