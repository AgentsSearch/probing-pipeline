      {
        "tool_name": "list_tables",
        "description": "List all tables in the SQLite database",
        "capability_tags": ["database", "sql", "schema", "introspection", "discovery"],
        "parameter_schema": {
          "type": "object",
          "properties": {}
        },
        "output_schema": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" }
            }
          }
        },
        "complexity_estimate": 0.1
      },
      {
        "tool_name": "describe_table",
        "description": "Get the schema information for a specific table",
        "capability_tags": ["database", "sql", "schema", "introspection"],
        "parameter_schema": {
          "type": "object",
          "properties": {
            "table_name": { "type": "string", "description": "Name of the table to describe" }
          },
          "required": ["table_name"]
        },
        "output_schema": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" },
              "notnull": { "type": "integer" },
              "pk": { "type": "integer" }
            }
          }
        },
        "complexity_estimate": 0.15
      },
      {
        "tool_name": "create_table",
        "description": "Create a new table in the SQLite database",
        "capability_tags": ["database", "sql", "ddl", "schema", "write"],
        "parameter_schema": {
          "type": "object",
          "properties": {
            "query": { "type": "string", "description": "CREATE TABLE SQL statement" }
          },
          "required": ["query"]
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "message": { "type": "string" }
          }
        },
        "complexity_estimate": 0.25
      }
    ]
  },
