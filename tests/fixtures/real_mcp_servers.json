[
  {
    "server_id": "server-github",
    "mcp_server_url": "npx -y @modelcontextprotocol/server-github",
    "tools": [
      {
        "tool_name": "search_repositories",
        "description": "Search for GitHub repositories",
        "capability_tags": ["search", "repository_discovery", "code_search"],
        "parameter_schema": {
          "type": "object",
          "properties": {
            "query": { "type": "string", "description": "Search query (see GitHub search syntax)" },
            "page": { "type": "number", "description": "Page number for pagination (default: 1)" },
            "perPage": { "type": "number", "description": "Number of results per page (default: 30, max: 100)" }
          },
          "required": ["query"],
          "additionalProperties": false
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "total_count": { "type": "number" },
            "items": { "type": "array" }
          }
        },
        "complexity_estimate": 0.15
      },
      {
        "tool_name": "get_file_contents",
        "description": "Get the contents of a file or directory from a GitHub repository",
        "capability_tags": ["file_read", "repository_content", "code_retrieval"],
        "parameter_schema": {
          "type": "object",
          "properties": {
            "owner": { "type": "string", "description": "Repository owner (username or organization)" },
            "repo": { "type": "string", "description": "Repository name" },
            "path": { "type": "string", "description": "Path to the file or directory" },
            "branch": { "type": "string", "description": "Branch to get contents from" }
          },
          "required": ["owner", "repo", "path"],
          "additionalProperties": false
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "name": { "type": "string" },
            "content": { "type": "string" }
          }
        },
        "complexity_estimate": 0.1
      },
      {
        "tool_name": "create_issue",
        "description": "Create a new issue in a GitHub repository",
        "capability_tags": ["issue_management", "write_operation", "project_management"],
        "parameter_schema": {
          "type": "object",
          "properties": {
            "owner": { "type": "string" },
            "repo": { "type": "string" },
            "title": { "type": "string" },
            "body": { "type": "string" },
            "assignees": { "type": "array", "items": { "type": "string" } },
            "labels": { "type": "array", "items": { "type": "string" } }
          },
          "required": ["owner", "repo", "title"],
          "additionalProperties": false
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "number": { "type": "number" },
            "state": { "type": "string" },
            "title": { "type": "string" },
            "html_url": { "type": "string" }
          }
        },
        "complexity_estimate": 0.25
      },
      {
        "tool_name": "list_issues",
        "description": "List issues in a GitHub repository with filtering options",
        "capability_tags": ["issue_management", "read_operation", "filtering", "pagination"],
        "parameter_schema": {
          "type": "object",
          "properties": {
            "owner": { "type": "string" },
            "repo": { "type": "string" },
            "state": { "type": "string", "enum": ["open", "closed", "all"] },
            "sort": { "type": "string", "enum": ["created", "updated", "comments"] },
            "direction": { "type": "string", "enum": ["asc", "desc"] },
            "labels": { "type": "array", "items": { "type": "string" } },
            "page": { "type": "number" },
            "per_page": { "type": "number" }
          },
          "required": ["owner", "repo"],
          "additionalProperties": false
        },
        "output_schema": {
          "type": "array",
          "items": { "type": "object" }
        },
        "complexity_estimate": 0.15
      },
      {
        "tool_name": "create_pull_request",
        "description": "Create a new pull request in a GitHub repository",
        "capability_tags": ["pull_request_management", "write_operation", "code_review", "collaboration"],
        "parameter_schema": {
          "type": "object",
          "properties": {
            "owner": { "type": "string", "description": "Repository owner" },
            "repo": { "type": "string", "description": "Repository name" },
            "title": { "type": "string", "description": "Pull request title" },
            "body": { "type": "string", "description": "Pull request body" },
            "head": { "type": "string", "description": "Branch with changes" },
            "base": { "type": "string", "description": "Branch to merge into" },
            "draft": { "type": "boolean", "description": "Whether to create as draft" }
          },
          "required": ["owner", "repo", "title", "head", "base"],
          "additionalProperties": false
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "number": { "type": "number" },
            "state": { "type": "string" },
            "html_url": { "type": "string" }
          }
        },
        "complexity_estimate": 0.35
      }
    ]
  },
  {
    "server_id": "server-filesystem",
    "mcp_server_url": "npx -y @modelcontextprotocol/server-filesystem /tmp",
    "tools": [
      {
        "tool_name": "read_file",
        "description": "Read the complete contents of a file from the file system as text. Handles various text encodings and provides detailed error messages if the file cannot be read.",
        "capability_tags": ["file_read", "text_processing", "encoding_handling"],
        "parameter_schema": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "description": "Absolute or relative path to the file to read" },
            "head": { "type": "number", "description": "Returns only the first N lines" },
            "tail": { "type": "number", "description": "Returns only the last N lines" }
          },
          "required": ["path"],
          "additionalProperties": false
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "content": { "type": "string" }
          }
        },
        "complexity_estimate": 0.15
      },
      {
        "tool_name": "write_file",
        "description": "Create a new file or completely overwrite an existing file with new content. Use with caution as it will overwrite existing files without warning.",
        "capability_tags": ["file_write", "file_create", "text_processing"],
        "parameter_schema": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "description": "Path to the file to write" },
            "content": { "type": "string", "description": "Content to write" }
          },
          "required": ["path", "content"],
          "additionalProperties": false
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "message": { "type": "string" }
          }
        },
        "complexity_estimate": 0.2
      },
      {
        "tool_name": "list_directory",
        "description": "Get a detailed listing of all files and directories in a specified path. Results clearly distinguish between files and directories with [FILE] and [DIR] prefixes.",
        "capability_tags": ["directory_listing", "filesystem_navigation", "file_discovery"],
        "parameter_schema": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "description": "Path to the directory to list" }
          },
          "required": ["path"],
          "additionalProperties": false
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "entries": { "type": "string" }
          }
        },
        "complexity_estimate": 0.1
      },
      {
        "tool_name": "search_files",
        "description": "Recursively search for files and directories matching a glob pattern. Returns full paths to all matching items.",
        "capability_tags": ["file_search", "glob_matching", "recursive_search", "pattern_matching"],
        "parameter_schema": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "description": "Base directory to search from" },
            "pattern": { "type": "string", "description": "Glob pattern to match (e.g. '**/*.py')" },
            "excludePatterns": { "type": "array", "items": { "type": "string" }, "description": "Patterns to exclude" }
          },
          "required": ["path", "pattern"],
          "additionalProperties": false
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "matches": { "type": "string" }
          }
        },
        "complexity_estimate": 0.35
      },
      {
        "tool_name": "create_directory",
        "description": "Create a new directory or ensure a directory exists. Can create multiple nested directories in one operation.",
        "capability_tags": ["directory_create", "filesystem_setup"],
        "parameter_schema": {
          "type": "object",
          "properties": {
            "path": { "type": "string", "description": "Path to directory to create" }
          },
          "required": ["path"],
          "additionalProperties": false
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "message": { "type": "string" }
          }
        },
        "complexity_estimate": 0.05
      },
      {
        "tool_name": "move_file",
        "description": "Move or rename files and directories. Can move files between directories and rename them in a single operation.",
        "capability_tags": ["file_move", "file_rename", "filesystem_organization"],
        "parameter_schema": {
          "type": "object",
          "properties": {
            "source": { "type": "string", "description": "Path of file or directory to move" },
            "destination": { "type": "string", "description": "New path for the file or directory" }
          },
          "required": ["source", "destination"],
          "additionalProperties": false
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "message": { "type": "string" }
          }
        },
        "complexity_estimate": 0.15
      }
    ]
  },
  {
    "server_id": "server-brave-search",
    "mcp_server_url": "npx -y @modelcontextprotocol/server-brave-search",
    "tools": [
      {
        "tool_name": "brave_web_search",
        "description": "Performs a web search using the Brave Search API, ideal for general queries, news, articles, and online content. Returns a list of web results with title, description, and URL.",
        "capability_tags": ["web_search", "information_retrieval", "news_search", "content_discovery"],
        "parameter_schema": {
          "type": "object",
          "properties": {
            "query": { "type": "string", "description": "Search query (max 400 chars, 50 words)", "maxLength": 400 },
            "count": { "type": "number", "description": "Number of results (1-20, default 10)", "minimum": 1, "maximum": 20 },
            "offset": { "type": "number", "description": "Pagination offset (max 9, default 0)", "minimum": 0, "maximum": 9 }
          },
          "required": ["query"]
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "results": { "type": "string", "description": "Formatted text with title, description, URL per result" }
          }
        },
        "complexity_estimate": 0.15
      },
      {
        "tool_name": "brave_local_search",
        "description": "Searches for local businesses and places using Brave's Local Search API. Best for queries related to physical locations, businesses, restaurants, services. Returns business names, addresses, ratings, phone numbers, and opening hours.",
        "capability_tags": ["local_search", "business_lookup", "location_search", "place_discovery"],
        "parameter_schema": {
          "type": "object",
          "properties": {
            "query": { "type": "string", "description": "Local search query (e.g. 'pizza near Central Park')", "maxLength": 400 },
            "count": { "type": "number", "description": "Number of results (1-20, default 5)", "minimum": 1, "maximum": 20 }
          },
          "required": ["query"]
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "results": { "type": "string", "description": "Formatted business info with name, address, rating, phone, hours" }
          }
        },
        "complexity_estimate": 0.25
      }
    ]
  },
  {
    "server_id": "server-sqlite",
    "mcp_server_url": "uvx mcp-server-sqlite --db-path /tmp/test.db",
    "tools": [
      {
